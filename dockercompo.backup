
services:
 
  trainee-mysql:
    image: mysql:8.0
    container_name: trainee-mysql
    restart: always
    volumes:
      - mysql_data:/var/lib/mysql
    ports:
      - "3307:3306"
    environment:
      MYSQL_ROOT_PASSWORD: simform@123
      MYSQL_DATABASE: my_project_db
      MYSQL_USER: myuser
      MYSQL_PASSWORD: simform@123
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 5s
      timeout: 5s
      retries: 10
 
  trainee_backend:
    build:
      context: ./trainee_backend
      dockerfile: Dockerfile
    container_name: trainee_backend
    restart: unless-stopped
    ports:
      - "5000:5000"
    env_file:
      - .env
    depends_on:
      trainee-mysql:
        condition: service_healthy   
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5000/items"]
      interval: 10s
      timeout: 5s
      retries: 5

  trainee_frontend:
    build:
      context: ./trainee_frontend/
    image: frontend-image
    container_name: trainee_frontend
    ports:
      - "5001:80"

    depends_on:
      - trainee_backend

volumes:
  mysql_data: